{
  "name": "student-journeys",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "codex:feature:start": "tsx scripts/codexWorkflow.ts start-feature",
    "codex:checkpoint": "tsx scripts/codexWorkflow.ts checkpoint",
    "codex:finish": "tsx scripts/codexWorkflow.ts finish-feature",
    "codex:pr:summary": "tsx scripts/codexWorkflow.ts pr-summary",
    "codex:pr:validate": "tsx scripts/codexWorkflow.ts validate-pr-metadata",
    "dev": "concurrently -k -n api,web \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/server/dev.ts",
    "dev:web": "vite --host 0.0.0.0 --port 4173",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.3",
    "@tailwindcss/vite": "^4.1.16",
    "hono": "^4.10.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.16",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "1.59.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "jsdom": "^27.0.0",
    "typescript": "^5.9.2",
    "tsx": "^4.20.6",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
